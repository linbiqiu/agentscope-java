# Test environment variables (local testing)
FEISHU_AGENT_APP_IMAGE=feishu-agent-app:latest

POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# FEISHU_WEBSOCKET_URL is optional and handled by SDK/client when omitted.
FEISHU_WEBSOCKET_APP_ID=cli_xxx
FEISHU_WEBSOCKET_APP_SECRET=xxx

# AI router defaults (override in env when needed)
AI_ROUTER_BASE_URL=https://your-ai-router.example.com
AI_ROUTER_API_KEY=replace-with-test-key
AI_ROUTER_PROVIDER=openai
AI_ROUTER_MODEL=gpt-4.1
AI_ROUTER_TIMEOUT_SECONDS=60
AI_ROUTER_MAX_TOKENS=4096
AI_ROUTER_TEMPERATURE=0.2

SPRING_PROFILES_ACTIVE=test
