# Production environment variables
# Copy this file to .env.prod and fill real values before deployment.
FEISHU_AGENT_APP_IMAGE=your-registry/feishu-agent-app:2026.05.23-01

POSTGRES_USER=feishu_app
POSTGRES_PASSWORD=PLEASE_USE_STRONG_PASSWORD

# FEISHU_WEBSOCKET_URL is optional and handled by SDK/client when omitted.
FEISHU_WEBSOCKET_APP_ID=cli_xxx
FEISHU_WEBSOCKET_APP_SECRET=xxx

# AI router defaults (override in env when needed)
AI_ROUTER_BASE_URL=https://your-ai-router.example.com
AI_ROUTER_API_KEY=replace-with-prod-key
AI_ROUTER_PROVIDER=anthropic
AI_ROUTER_MODEL=claude-sonnet-4-6
AI_ROUTER_TIMEOUT_SECONDS=60
AI_ROUTER_MAX_TOKENS=4096
AI_ROUTER_TEMPERATURE=0.2

FEISHU_RUNTIME_SKILL_REPO_DIR=/data/skill-repo
FEISHU_RUNTIME_SKILL_REPO_REFRESH_INTERVAL_MS=5000

SPRING_PROFILES_ACTIVE=prod
